# Supabase (service role key — needed to read/write the queue)
SUPABASE_URL=https://dbfizsgvjcbzcwhcmtzg.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# X API (Bearer Token — needed to look up user's latest tweet)
X_BEARER_TOKEN=your-x-bearer-token-here

# Worker config
POLL_INTERVAL_MS=30000
MAX_ATTEMPTS=3
BACKOFF_MINUTES=5

# Logging
LOG_LEVEL=info
